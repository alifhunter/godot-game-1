[gd_scene format=3]

[node name="HelpView" type="MarginContainer"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 2
theme_override_constants/margin_top = 2
theme_override_constants/margin_right = 2
theme_override_constants/margin_bottom = 2

[node name="HelpPanel" type="PanelContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="HelpMargin" type="MarginContainer" parent="HelpPanel"]
theme_override_constants/margin_left = 18
theme_override_constants/margin_top = 18
theme_override_constants/margin_right = 18
theme_override_constants/margin_bottom = 18

[node name="HelpVBox" type="VBoxContainer" parent="HelpPanel/HelpMargin"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 10

[node name="HelpTitle" type="Label" parent="HelpPanel/HelpMargin/HelpVBox"]
text = "HELP"

[node name="HelpTextLabel" type="RichTextLabel" parent="HelpPanel/HelpMargin/HelpVBox"]
custom_minimum_size = Vector2(0, 420)
size_flags_vertical = 3
fit_content = false
scroll_active = true
selection_enabled = true
text = "Help content will appear here."
