[gd_scene format=3]

[node name="ActionPanel" type="PanelContainer"]
clip_contents = true
size_flags_vertical = 3

[node name="ActionMargin" type="MarginContainer" parent="."]
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 12

[node name="ActionVBox" type="VBoxContainer" parent="ActionMargin"]
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_constants/separation = 14

[node name="HeaderVBox" type="VBoxContainer" parent="ActionMargin/ActionVBox"]
theme_override_constants/separation = 8

[node name="MarketHeaderRow" type="HBoxContainer" parent="ActionMargin/ActionVBox/HeaderVBox"]
theme_override_constants/separation = 8

[node name="CompanyNameLabel" type="Label" parent="ActionMargin/ActionVBox/HeaderVBox/MarketHeaderRow"]
custom_minimum_size = Vector2(48, 22)
theme_override_font_sizes/font_size = 12
text = "NO SELECTION"
vertical_alignment = 1

[node name="CurrentPriceLabel" type="Label" parent="ActionMargin/ActionVBox/HeaderVBox/MarketHeaderRow"]
theme_override_font_sizes/font_size = 12
text = "0"
vertical_alignment = 1

[node name="PriceChangeLabel" type="Label" parent="ActionMargin/ActionVBox/HeaderVBox/MarketHeaderRow"]
theme_override_font_sizes/font_size = 12
text = "+0 (+0.00%)"
vertical_alignment = 1

[node name="MarketHeaderSpacer" type="Control" parent="ActionMargin/ActionVBox/HeaderVBox/MarketHeaderRow"]
size_flags_horizontal = 3

[node name="MarketMenuLabel" type="Label" parent="ActionMargin/ActionVBox/HeaderVBox/MarketHeaderRow"]
theme_override_font_sizes/font_size = 14
text = "..."
vertical_alignment = 1

[node name="SelectionLabel" type="Label" parent="ActionMargin/ActionVBox/HeaderVBox"]
visible = false
theme_override_font_sizes/font_size = 12
text = "-"

[node name="MarketStatGrid" type="GridContainer" parent="ActionMargin/ActionVBox/HeaderVBox"]
size_flags_horizontal = 3
columns = 6
theme_override_constants/h_separation = 8
theme_override_constants/v_separation = 4

[node name="OpenLabel" type="Label" parent="ActionMargin/ActionVBox/HeaderVBox/MarketStatGrid"]
custom_minimum_size = Vector2(42, 0)
theme_override_font_sizes/font_size = 12
text = "Open"

[node name="OpenValueLabel" type="Label" parent="ActionMargin/ActionVBox/HeaderVBox/MarketStatGrid"]
custom_minimum_size = Vector2(54, 0)
theme_override_font_sizes/font_size = 12
horizontal_alignment = 2
text = "-"

[node name="PrevLabel" type="Label" parent="ActionMargin/ActionVBox/HeaderVBox/MarketStatGrid"]
custom_minimum_size = Vector2(42, 0)
theme_override_font_sizes/font_size = 12
text = "Prev"

[node name="PrevValueLabel" type="Label" parent="ActionMargin/ActionVBox/HeaderVBox/MarketStatGrid"]
