[gd_scene format=3]

[node name="WatchlistPanel" type="PanelContainer"]
clip_contents = true
size_flags_vertical = 3

[node name="WatchlistMargin" type="MarginContainer" parent="."]
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 12

[node name="WatchlistVBox" type="VBoxContainer" parent="WatchlistMargin"]
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_constants/separation = 0

[node name="StockListTabs" type="TabContainer" parent="WatchlistMargin/WatchlistVBox"]
clip_contents = true
size_flags_horizontal = 3
size_flags_vertical = 3

[node name="WatchlistTab" type="VBoxContainer" parent="WatchlistMargin/WatchlistVBox/StockListTabs"]
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_constants/separation = 10

[node name="WatchlistActionRow" type="HBoxContainer" parent="WatchlistMargin/WatchlistVBox/StockListTabs/WatchlistTab"]
size_flags_horizontal = 3
theme_override_constants/separation = 8

[node name="AddWatchlistButton" type="Button" parent="WatchlistMargin/WatchlistVBox/StockListTabs/WatchlistTab/WatchlistActionRow"]
custom_minimum_size = Vector2(0, 40)
size_flags_horizontal = 3
text = "Add Watchlist"

[node name="RemoveWatchlistButton" type="Button" parent="WatchlistMargin/WatchlistVBox/StockListTabs/WatchlistTab/WatchlistActionRow"]
custom_minimum_size = Vector2(0, 40)
size_flags_horizontal = 3
text = "Remove"

[node name="WatchlistEmptyLabel" type="Label" parent="WatchlistMargin/WatchlistVBox/StockListTabs/WatchlistTab"]
autowrap_mode = 3
text = "No stocks in your watchlist yet."

[node name="CompanyList" type="ItemList" parent="WatchlistMargin/WatchlistVBox/StockListTabs/WatchlistTab"]
custom_minimum_size = Vector2(0, 360)
size_flags_horizontal = 3
size_flags_vertical = 3

[node name="AllStocksTab" type="VBoxContainer" parent="WatchlistMargin/WatchlistVBox/StockListTabs"]
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_constants/separation = 8

[node name="AllStocksSearchInput" type="LineEdit" parent="WatchlistMargin/WatchlistVBox/StockListTabs/AllStocksTab"]
custom_minimum_size = Vector2(0, 36)
size_flags_horizontal = 3
placeholder_text = "Search ticker or company"
clear_button_enabled = true

[node name="AllStocksScroll" type="ScrollContainer" parent="WatchlistMargin/WatchlistVBox/StockListTabs/AllStocksTab"]
size_flags_horizontal = 3
size_flags_vertical = 3
horizontal_scroll_mode = 0

[node name="AllStocksRows" type="VBoxContainer" parent="WatchlistMargin/WatchlistVBox/StockListTabs/AllStocksTab/AllStocksScroll"]
size_flags_horizontal = 3
theme_override_constants/separation = 0

[node name="PortfolioTab" type="VBoxContainer" parent="WatchlistMargin/WatchlistVBox/StockListTabs"]
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_constants/separation = 0

[node name="PortfolioScroll" type="ScrollContainer" parent="WatchlistMargin/WatchlistVBox/StockListTabs/PortfolioTab"]
size_flags_horizontal = 3
size_flags_vertical = 3
horizontal_scroll_mode = 0

[node name="PortfolioRows" type="VBoxContainer" parent="WatchlistMargin/WatchlistVBox/StockListTabs/PortfolioTab/PortfolioScroll"]
size_flags_horizontal = 3
theme_override_constants/separation = 0

[node name="PortfolioEmptyLabel" type="Label" parent="WatchlistMargin/WatchlistVBox/StockListTabs/PortfolioTab/PortfolioScroll/PortfolioRows"]
autowrap_mode = 3
text = "No owned stocks yet."
